{
  "name": "claude-proxy-v2",
  "displayName": "Claude Proxy v2",
  "description": "Simple proxy for Claude API with multiple AI provider support",
  "version": "0.0.1",
  "publisher": "uzhao",
  "homepage": "https://github.com/uzhao/claude-proxy-vscode-v2#readme",
  "bugs": {
    "url": "https://github.com/uzhao/claude-proxy-vscode-v2/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/uzhao/claude-proxy-vscode-v2.git"
  },
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "ai",
    "proxy",
    "anthropic",
    "glm",
    "kimi",
    "deepseek"
  ],
  "license": "MIT",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeProxy.openMenu",
        "title": "Claude Proxy: 打开菜单"
      }
    ],
    "configuration": [
      {
        "title": "Claude Proxy",
        "properties": {
          "claudeProxy.port": {
            "type": "number",
            "default": 4001,
            "description": "本地代理监听端口(固定使用;被占用时会报错,请改此值后重载窗口)",
            "scope": "machine"
          }
        }
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "tsc -p ./ && node --test \"out/**/*.test.js\""
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}

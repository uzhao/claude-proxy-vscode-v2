{
  "name": "claude-proxy",
  "displayName": "Claude Proxy",
  "description": "Simple proxy for Claude API with multiple AI provider support",
  "version": "0.0.9",
  "publisher": "uzhao",
  "homepage": "https://github.com/uzhao/claude-proxy-vscode#readme",
  "bugs": {
    "url": "https://github.com/uzhao/claude-proxy-vscode/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/uzhao/claude-proxy-vscode.git"
  },
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "claude",
    "ai",
    "proxy",
    "anthropic",
    "glm",
    "kimi",
    "deepseek"
  ],
  "license": "MIT",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeProxy.openMenu",
        "title": "Claude Proxy: 打开菜单"
      },
      {
        "command": "claudeProxy.editConfig",
        "title": "Claude Proxy: 编辑配置文件"
      }
    ],
    "configuration": [
      {
        "title": "Claude Proxy",
        "properties": {
          "claudeProxy.enableJsonLogging": {
            "type": "boolean",
            "default": false,
            "description": "是否将请求和响应保存为JSON文件到~/.claude/proxy/log目录",
            "scope": "machine"
          }
        }
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "tsc -p ./ && node --test out/**/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}
